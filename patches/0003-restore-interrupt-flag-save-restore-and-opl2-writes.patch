-    // ASM: pushf
+    dword saved_flags = SaveInterruptFlag();
 
     disable();
 
-    // ASM: mov   dx,0x0388
-    // ASM: mov   al,[addr]
-    // ASM: out   dx,al
-    // ASM: in    al,dx  /* 6 `in` instructions for a 3.4 us delay */
-    // ASM: in    al,dx
-    // ASM: in    al,dx
-    // ASM: in    al,dx
-    // ASM: in    al,dx
-    // ASM: in    al,dx
-    // ASM: mov   dx,0x0389
-    // ASM: mov   al,[data]
-    // ASM: out   dx,al
+    outportb(0x0388, addr);
+    outportb(0x0389, data);
 
-    // ASM: popf
+    RestoreInterruptFlag(saved_flags);
 
     // ASM: mov   dx,0x0388
     // ASM: in    al,dx  /* 35 `in` instructions for a 23.5 us delay */
@@ -551,14 +541,14 @@ void StopAdLib(void)
 
